# -----------------------------
# PostgreSQL
# -----------------------------
PGHOST=127.0.0.1
PGPORT=5432
PGDATABASE=openalex
PGUSER=postgres
PGPASSWORD=changeme
# Optional: disable/enable SSL, e.g. require/disable
PGSSLMODE=

# -----------------------------
# Aliyun OSS
# -----------------------------
ALIYUN_OSS_ACCESS_KEY_ID=
ALIYUN_OSS_ACCESS_KEY_SECRET=
ALIYUN_OSS_BUCKET=
# Endpoint without bucket prefix, e.g. oss-cn-hangzhou.aliyuncs.com
ALIYUN_OSS_ENDPOINT=
# Public URL prefix, e.g. https://your-cdn.example.com or https://<bucket>.<endpoint>
ALIYUN_OSS_PUBLIC_BASE_URL=
# Optional object key prefix
ALIYUN_OSS_KEY_PREFIX=openalex
# Optional response header for uploaded objects
ALIYUN_OSS_CACHE_CONTROL=public,max-age=31536000,immutable

# -----------------------------
# Qwen / LLM (one of each alias pair is enough)
# -----------------------------
LLM_API_KEY=
# QWEN_API_KEY=
LLM_BASE_URL=
# QWEN_BASE_URL=
LLM_MODEL=qwen3.5-plus
# QWEN_MODEL=qwen3.5-plus
QWEN_RESPONSE_PATH=/responses

# Enable web_search tool (profile-page discovery)
QWEN_ENABLE_WEB_SEARCH=true
QWEN_MAX_CANDIDATES=3
QWEN_MIN_CONFIDENCE=0.55
QWEN_MAX_OUTPUT_TOKENS=256
QWEN_TIMEOUT_SECONDS=120
QWEN_MIN_CALL_INTERVAL_SECONDS=0
QWEN_SDK_MAX_RETRIES=0

# -----------------------------
# Profile page -> image extraction
# -----------------------------
# Optional: defaults to REQUEST_TIMEOUT_SECONDS if empty
PROFILE_PAGE_FETCH_TIMEOUT_SECONDS=20
PROFILE_PAGE_MAX_COUNT=5
PROFILE_IMAGE_MAX_PER_PAGE=10
PROFILE_IMAGE_MIN_SCORE=1.0

# -----------------------------
# General HTTP / image validation
# -----------------------------
ALLOWED_MIME=image/jpeg,image/png,image/webp
MIN_IMAGE_EDGE_PX=96
REQUEST_TIMEOUT_SECONDS=20
MAX_RETRIES=3
GLOBAL_QPS_LIMIT=2
RETRY_BASE_SECONDS=1.5
RETRY_MAX_SECONDS=60
RETRY_JITTER_RATIO=0.25
RETRY_429_MIN_DELAY_SECONDS=8
